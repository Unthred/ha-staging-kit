# Copy to data/sidecar/config.env and data/sidecar/secrets/ — see README.md

# Paths on the Docker host (absolute)
HA_CONFIG_REPO=/path/to/your/HomeAssistant-config-git
HA_STAGING_CONFIG=/path/to/staging/homeassistant
SIDECAR_DATA=./data/sidecar
MIRROR_DATA=./data/mirror

# Prod HA (read — person sync, optional SSH). Split DNS / HAProxy example:
PROD_HA_URL=https://home.yeradonkey.com
HA_SECRETS=user@prod-host:/homeassistant/secrets.yaml
HA_STORAGE=user@prod-host:/homeassistant/.storage/

# Staging HA (write — person sync). Split DNS / HAProxy example:
STAGING_HA_URL=https://ha-staging.yeradonkey.com

# Staging MQTT client → kit mirror (re-applied after storage sync).
# Must resolve to the kit Docker host on port 1883 — not an HAProxy HTTPS frontend.
# STAGING_MQTT_BROKER=192.168.1.11
# KIT_MQTT_BROKER=192.168.1.11
# STAGING_MQTT_PORT=1883

# Optional — override kit host LAN IP when auto-detection fails (Unraid etc.)
# KIT_LAN_IP=192.168.1.11

# Git branch to apply to staging config
HA_BRANCH=staging

# MQTT mirror — prod broker (direct to HA host; not the HAProxy FQDN)
PROD_MQTT_HOST=192.168.1.10
PROD_MQTT_PORT=1883
MIRROR_PORT=1883

# Optional — git identity for commits from the staging console (required in container)
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com

# Web console (8080 is UniFi on this host — use 8081 or another free host port)
CONSOLE_PORT=8081

# Sidecar tuning
PERSON_POLL_INTERVAL=60
STORAGE_SYNC_INTERVAL=86400
# auto = apply config only on first bootstrap; 1 = every start; 0 = never
APPLY_ON_START=auto

# Optional — Docker container names (defaults match docker-compose.yml)
# SYNC_CONTAINER=ha-staging-kit-sync
# KIT_CONTAINER=ha-staging-kit
# MIRROR_CONTAINER=ha-staging-kit-mqtt-mirror

# Optional — docker container name for staging HA (Operations → Restart)
# STAGING_HA_CONTAINER=Home-Assistant-Container
