# Copy to data/sidecar/config.env and data/sidecar/secrets/ — see README.md

# Paths on the Docker host (absolute)
HA_CONFIG_REPO=/path/to/your/HomeAssistant-config-git
HA_STAGING_CONFIG=/path/to/staging/homeassistant
SIDECAR_DATA=./data/sidecar
MIRROR_DATA=./data/mirror

# Prod HA (read — person sync, optional SSH)
PROD_HA_URL=http://192.168.1.10:8123
HA_SECRETS=user@prod-host:/homeassistant/secrets.yaml
HA_STORAGE=user@prod-host:/homeassistant/.storage/

# Staging HA (write — person sync)
STAGING_HA_URL=http://127.0.0.1:8123

# Git branch to apply to staging config
HA_BRANCH=staging

# MQTT mirror — prod broker
PROD_MQTT_HOST=192.168.1.10
PROD_MQTT_PORT=1883
MIRROR_PORT=1883

# Web console (8080 is UniFi on this host — use 8081 or another free host port)
CONSOLE_PORT=8081

# Sidecar tuning
PERSON_POLL_INTERVAL=60
STORAGE_SYNC_INTERVAL=86400
APPLY_ON_START=1

# Optional — docker container name for staging HA (Operations → Restart)
# STAGING_HA_CONTAINER=Home-Assistant-Container
