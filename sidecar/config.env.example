# ha-staging-sidecar runtime config (copy to /sidecar-data/config.env)
REPO_DIR=/repo
HA_CONFIG=/ha-config
HA_BRANCH=staging
STAGING_HA_URL=http://127.0.0.1:8123
PERSON_POLL_INTERVAL=60
STORAGE_SYNC_INTERVAL=86400
APPLY_ON_START=1
SKIP_STORAGE_SYNC=0
SECRETS_DIR=/sidecar-data/secrets
# PROD_API_TOKEN_FILE and STAGING_API_TOKEN_FILE default under SECRETS_DIR
# SSH_KEY_FILE defaults to ${SECRETS_DIR}/id_ed25519
# HA_SECRETS=squiggley@prod-host:/homeassistant/secrets.yaml
# HA_STORAGE=squiggley@prod-host:/homeassistant/.storage/
SIDECAR_TEMPLATE=/sidecar/templates/packages-sidecar.yaml
